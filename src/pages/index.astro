---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { CATEGORIES } from '../config';
import { getCollection } from 'astro:content';
import { getSlug } from '../utils/post';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 12);

const featuredPosts = sortedPosts.slice(0, 3);
const recentPosts = sortedPosts.slice(3);

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '好物123',
  url: 'https://haowu123.com',
  description: '精选优质好物，让生活更美好',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://haowu123.com/search?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout schema={websiteSchema}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary-500 via-red-500 to-orange-500 text-white">
    <div class="max-w-7xl mx-auto px-4 py-16 md:py-24">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-6 text-balance">
          找到最适合你的<span class="underline decoration-white/30">好物</span>
        </h1>
        <p class="text-xl md:text-2xl text-white/90 leading-relaxed mb-8">
          数码、家居、厨房、办公... 真实测评，专业推荐，让你的每一分钱都花在刀刃上
        </p>
        <div class="flex flex-wrap gap-3">
          {CATEGORIES.slice(0, 4).map(cat => (
            <a href={`/categories/${cat.slug}`}
              class="px-5 py-3 bg-white/20 backdrop-blur-sm rounded-full font-medium hover:bg-white/30 transition-all border border-white/20">
              {cat.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 分类导航 -->
  <section class="max-w-7xl mx-auto px-4 -mt-8 relative z-10">
    <div class="grid grid-cols-3 md:grid-cols-6 gap-3">
      {CATEGORIES.map(cat => (
        <a href={`/categories/${cat.slug}`}
          class="bg-white rounded-2xl p-4 text-center shadow-sm hover:shadow-md transition-all border border-gray-100 group">
          <div class="text-3xl mb-2">
            {cat.slug === 'digital' && '📱'}
            {cat.slug === 'home' && '🏠'}
            {cat.slug === 'kitchen' && '🍳'}
            {cat.slug === 'office' && '💼'}
            {cat.slug === 'travel' && '✈️'}
            {cat.slug === 'personal-care' && '💄'}
          </div>
          <h3 class="text-sm font-semibold text-gray-800 group-hover:text-primary-600 transition-colors">{cat.name}</h3>
        </a>
      ))}
    </div>
  </section>

  <!-- 精选文章 -->
  <section class="max-w-7xl mx-auto px-4 mt-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl md:text-3xl font-black text-gray-900">🔥 精选推荐</h2>
      <a href="/blog" class="text-primary-600 hover:text-primary-700 font-medium text-sm">查看全部 →</a>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {featuredPosts.map(post => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={getSlug(post.id)}
          category={post.data.category}
          tags={post.data.tags}
          heroImage={post.data.heroImage}
        />
      ))}
    </div>

    <!-- 更多文章 -->
    {
      recentPosts.length > 0 && (
        <div class="grid md:grid-cols-3 gap-6 mt-6">
          {recentPosts.slice(0, 6).map(post => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={getSlug(post.id)}
              category={post.data.category}
              tags={post.data.tags}
              heroImage={post.data.heroImage}
            />
          ))}
        </div>
      )
    }
  </section>

  <!-- 底部CTA -->
  <section class="max-w-7xl mx-auto px-4 mt-16 mb-8">
    <div class="bg-gradient-to-r from-gray-800 to-gray-900 rounded-3xl p-10 text-center text-white">
      <h2 class="text-3xl font-black mb-4">🎯 每周更新精品好物推荐</h2>
      <p class="text-gray-300 mb-6 text-lg">订阅我们的推送，不错过任何好物推荐</p>
      <a href="/rss.xml" class="inline-flex items-center gap-2 px-8 py-3 bg-orange-500 hover:bg-orange-600 rounded-full font-bold transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/></svg>
        RSS 订阅
      </a>
    </div>
  </section>
</BaseLayout>
