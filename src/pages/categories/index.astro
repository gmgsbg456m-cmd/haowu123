---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CATEGORIES } from '../../config';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);

const categoryCounts = CATEGORIES.map(cat => ({
  ...cat,
  count: posts.filter(p => p.data.category === cat.slug).length,
}));
---

<BaseLayout title="分类">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <h1 class="text-3xl md:text-4xl font-black text-gray-900 mb-8">📂 分类浏览</h1>

    <div class="grid md:grid-cols-3 gap-6">
      {categoryCounts.map(cat => (
        <a href={`/categories/${cat.slug}`}
          class="product-card p-6 hover:border-primary-200">
          <div class="text-4xl mb-3">
            {cat.slug === 'digital' && '📱'}
            {cat.slug === 'home' && '🏠'}
            {cat.slug === 'kitchen' && '🍳'}
            {cat.slug === 'office' && '💼'}
            {cat.slug === 'travel' && '✈️'}
            {cat.slug === 'personal-care' && '💄'}
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">{cat.name}</h3>
          <p class="text-gray-500 text-sm mb-3">{cat.description}</p>
          <span class="text-primary-600 font-medium">{cat.count} 篇文章</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
