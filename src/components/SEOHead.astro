---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
  noIndex?: boolean;
}

const { title, description, ogImage = '/images/og-default.jpg', canonicalURL, noIndex } = Astro.props;
const siteUrl = 'https://haowu123.com';
---

<title>{title}</title>
<meta name="description" content={description} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL || siteUrl} />
<meta property="og:image" content={new URL(ogImage, siteUrl).href} />
<meta property="og:site_name" content="好物123" />
<meta property="og:locale" content="zh_CN" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(ogImage, siteUrl).href} />

<!-- Canonical -->
{canonicalURL && <link rel="canonical" href={canonicalURL} />}

<!-- Robots -->
{noIndex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow" />}

<!-- 百度验证 -->
<meta name="baidu-site-verification" content="code-xxxxxxxx" />
