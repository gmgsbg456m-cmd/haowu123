---
import { formatDate } from '../utils/date';
import { getReadingTime } from '../utils/readingTime';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  category: string;
  tags?: string[];
  heroImage?: string;
}

const { title, description, pubDate, slug, category, tags = [], heroImage } = Astro.props;
const readingTime = getReadingTime(description + title);
---

<article class="product-card group">
  <a href={`/blog/${slug}`} class="block">
    <!-- 封面图 -->
    <div class="aspect-[16/9] bg-gradient-to-br from-gray-100 to-gray-200 overflow-hidden">
      {heroImage ? (
        <img src={heroImage} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
      ) : (
        <div class="w-full h-full flex items-center justify-center text-5xl">
          🛍️
        </div>
      )}
    </div>

    <!-- 内容 -->
    <div class="p-5">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-xs font-medium text-primary-600 bg-primary-50 px-2 py-0.5 rounded-full">
          {category}
        </span>
        <span class="text-xs text-gray-400">{formatDate(pubDate)}</span>
      </div>

      <h3 class="font-bold text-lg text-gray-900 group-hover:text-primary-600 transition-colors line-clamp-2 mb-2">
        {title}
      </h3>

      <p class="text-sm text-gray-500 line-clamp-2 mb-3 leading-relaxed">
        {description}
      </p>

      <div class="flex items-center justify-between">
        <span class="text-xs text-gray-400">{readingTime} 分钟阅读</span>
        <span class="text-sm font-medium text-primary-600 flex items-center gap-1 group-hover:gap-2 transition-all">
          阅读更多
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </span>
      </div>
    </div>
  </a>
</article>
