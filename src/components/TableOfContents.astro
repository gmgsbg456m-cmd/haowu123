---
interface Heading {
  level: number;
  text: string;
  id: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
---

{
  headings.length > 0 && (
    <nav class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
      <h4 class="font-bold text-gray-900 mb-3 text-sm uppercase tracking-wider">📑 目录</h4>
      <ul class="space-y-1.5">
        {headings.map(heading => (
          <li>
            <a
              href={`#${heading.id}`}
              class={`block text-sm text-gray-500 hover:text-primary-600 transition-colors py-1 ${
                heading.level === 3 ? 'pl-4 border-l-2 border-gray-200' : ''
              }`}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
