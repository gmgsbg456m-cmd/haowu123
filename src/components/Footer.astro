---
import { SITE, CATEGORIES } from '../config';
---

<footer class="bg-gray-900 text-gray-300 mt-20">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid md:grid-cols-4 gap-8">
      <!-- 关于 -->
      <div class="md:col-span-2">
        <h3 class="text-white font-bold text-lg mb-3">{SITE.title}</h3>
        <p class="text-sm leading-relaxed text-gray-400">
          {SITE.description}<br/>
          我们致力于用真实的测评和专业的推荐，帮您找到最适合的好物。所有推荐均经过严格筛选。
        </p>
      </div>

      <!-- 分类 -->
      <div>
        <h4 class="text-white font-semibold mb-3">热门分类</h4>
        <ul class="space-y-2 text-sm">
          {CATEGORIES.slice(0, 4).map(cat => (
            <li>
              <a href={`/categories/${cat.slug}`} class="hover:text-white transition-colors">{cat.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- 链接 -->
      <div>
        <h4 class="text-white font-semibold mb-3">链接</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/about" class="hover:text-white transition-colors">关于我们</a></li>
          <li><a href="/privacy" class="hover:text-white transition-colors">隐私政策</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">联系我们</a></li>
          <li><a href="/rss.xml" class="hover:text-white transition-colors">RSS 订阅</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-8 pt-8 text-sm text-center text-gray-500">
      <p>&copy; {new Date().getFullYear()} {SITE.title}. All rights reserved.</p>
    </div>
  </div>
</footer>
