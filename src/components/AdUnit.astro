---
import { ADS } from '../config';

interface Props {
  slot: 'in-article-top' | 'in-article-bottom' | 'sidebar' | 'between-content';
}

const { slot } = Astro.props;

const placeholders: Record<string, string> = {
  'in-article-top': '🛍️ 好物推荐 · 广告位',
  'in-article-bottom': '🛍️ 相关好物 · 广告位',
  'sidebar': '🛒 精选好物',
  'between-content': '⭐ 为您推荐',
};

const enabled = ADS.adsense.enabled;
---

{
  enabled ? (
    <div class="ad-container my-8">
      <ins
        class="adsbygoogle"
        style="display:block"
        data-ad-client={ADS.adsense.clientId}
        data-ad-slot={slot === 'sidebar' ? '1234567890' : '0987654321'}
        data-ad-format="auto"
        data-full-width-responsive="true"
      ></ins>
      <script>
        (adsbygoogle = window.adsbygoogle || []).push({});
      </script>
    </div>
  ) : (
    <div class="ad-placeholder my-8 p-6 bg-gradient-to-r from-gray-50 to-gray-100 rounded-2xl border-2 border-dashed border-gray-200 text-center">
      <div class="text-gray-400 text-sm mb-2">{placeholders[slot]}</div>
      <div class="text-gray-300 text-xs">（AdSense审核通过后自动替换为广告）</div>
    </div>
  )
}
