---
import { SITE, CATEGORIES } from '../config';
---

<header class="bg-white shadow-sm sticky top-0 z-50 border-b border-gray-100">
  <nav class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-black text-xl text-gray-900 hover:text-primary-600 transition-colors">
      <span class="text-2xl">🛒</span>
      {SITE.title}
    </a>

    <!-- 导航链接 -->
    <div class="hidden md:flex items-center gap-1">
      <a href="/" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 transition-colors">
        首页
      </a>

      <!-- 分类下拉 -->
      <div class="relative group">
        <button class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 transition-colors flex items-center gap-1">
          分类
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="absolute top-full left-0 mt-1 bg-white rounded-xl shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 min-w-40">
          {CATEGORIES.map(cat => (
            <a href={`/categories/${cat.slug}`} class="block px-4 py-2.5 text-sm text-gray-600 hover:text-primary-600 hover:bg-primary-50 first:rounded-t-xl last:rounded-b-xl whitespace-nowrap">
              {cat.name}
            </a>
          ))}
        </div>
      </div>

      <a href="/blog" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 transition-colors">
        全部文章
      </a>

      <a href="/about" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 transition-colors">
        关于我们
      </a>
    </div>

    <!-- 移动端菜单（简化） -->
    <div class="md:hidden">
      <button id="mobile-menu-btn" class="p-2 rounded-lg text-gray-600 hover:bg-gray-100" aria-label="菜单">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </nav>
</header>
